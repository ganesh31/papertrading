{
  "name": "papertrading",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Equity-first paper trading system with plug-in asset modules.",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check": "turbo run lint test build",
    "cz": "cz"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    },
    "cz-emoji": {
      "conventional": true,
      "types": [
        {
          "emoji": "✨",
          "code": ":sparkles:",
          "description": "A new feature.",
          "name": "feat"
        },
        {
          "emoji": "🐛",
          "code": ":bug:",
          "description": "A bug fix.",
          "name": "fix"
        },
        {
          "emoji": "📚",
          "code": ":books:",
          "description": "Documentation only changes.",
          "name": "docs"
        },
        {
          "emoji": "💎",
          "code": ":gem:",
          "description": "Formatting, punctuation, etc.; no logic change.",
          "name": "style"
        },
        {
          "emoji": "📦",
          "code": ":package:",
          "description": "Refactoring production code.",
          "name": "refactor"
        },
        {
          "emoji": "⚡️",
          "code": ":zap:",
          "description": "A code change that improves performance.",
          "name": "perf"
        },
        {
          "emoji": "✅",
          "code": ":white_check_mark:",
          "description": "Adding or updating tests.",
          "name": "test"
        },
        {
          "emoji": "🛠",
          "code": ":hammer_and_wrench:",
          "description": "Build system or external dependencies.",
          "name": "build"
        },
        {
          "emoji": "👷",
          "code": ":construction_worker:",
          "description": "CI configuration or scripts.",
          "name": "ci"
        },
        {
          "emoji": "♻️",
          "code": ":recycle:",
          "description": "Other changes that do not touch src or test files.",
          "name": "chore"
        },
        {
          "emoji": "⏪",
          "code": ":rewind:",
          "description": "Reverts a previous commit.",
          "name": "revert"
        }
      ]
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "commitizen": "^4.3.1",
    "cz-emoji": "1.3.2-canary.2",
    "lefthook": "^2.1.6",
    "turbo": "^2.9.6"
  }
}
