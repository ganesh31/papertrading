# Shared
TZ=Asia/Kolkata

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=papertrading
POSTGRES_PASSWORD=papertrading
POSTGRES_DB=papertrading
DATABASE_URL=postgres://papertrading:papertrading@localhost:5432/papertrading?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Observability (local docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=papertrading
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# Gateway
GATEWAY_PORT=4000
# REST proxy targets (host gateway → local md)
MD_BASE_URL=http://localhost:6011

# pt CLI replay / HTTP client to md
MD_URL=http://localhost:6011

# Go MD service
MD_PORT=6011
# Optional NSE_EQ holiday list (defaults: Docker image path or ./infra/seed/holidays.json next to cwd).
# MARKET_HOLIDAYS_PATH=/absolute/path/to/holidays.json
# nse_replay (default) | angel_live (stub until Phase 11)
MD_ADAPTER=nse_replay
