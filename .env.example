# Shared
TZ=Asia/Kolkata

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=papertrading
POSTGRES_PASSWORD=papertrading
POSTGRES_DB=papertrading
DATABASE_URL=postgres://papertrading:papertrading@localhost:5432/papertrading?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Observability (local docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=papertrading
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# Gateway
GATEWAY_PORT=4000

# Go MD service
MD_PORT=6011
